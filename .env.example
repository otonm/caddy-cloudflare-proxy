# Cloudflare API token — needs Zone:Read + DNS:Edit permissions
CF_API_TOKEN=

# Tailscale API credentials
TS_API_KEY=
TS_TAILNET=          # e.g. "example.com" or "me"

# Caddy admin API URL (internal Docker network)
CADDY_ADMIN_URL=http://caddy:2019

# Let's Encrypt ACME default email (optional — can be set per-proxy in the UI instead)
ACME_EMAIL=

# App port exposed on host (default: 3000)
APP_PORT=3000

# Data directory inside container
DATA_DIR=/data

# Set to "true" to disable Tailscale IP auth (development only)
DISABLE_AUTH=false
