CF_API_TOKEN=

# Tailscale API credentials
TS_API_KEY=
TS_TAILNET=

# Caddy admin API URL (internal Docker network)
CADDY_ADMIN=0.0.0.0:2019

# Let's Encrypt ACME default email (optional — can be set per-proxy in the UI instead)
ACME_EMAIL=